{
  "name": "@academyos/dataset-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:questions:clean": "node scripts/rebuild-clean-dataset.mjs --source CSA_EXAMTOPICS.json --output CSA_EXAMTOPICS_READY.json",
    "convert:answers-detail": "node scripts/convert-answers-detail-to-questions.mjs",
    "convert:answers-detail:clipboard": "node scripts/convert-answers-detail-to-questions.mjs --from-clipboard --output CSA_EXAMTOPICS_FROM_ANSWERS_DETAIL.json",
    "convert:answers-detail:clipboard:merge": "node scripts/convert-answers-detail-to-questions.mjs --from-clipboard --output CSA_EXAMTOPICS_FROM_ANSWERS_DETAIL.json --merge-base CSA_EXAMTOPICS_READY.json --merge-output CSA_EXAMTOPICS_READY_MERGED.json",
    "import:questions": "node scripts/import-questions.mjs",
    "import:questions:ready": "node scripts/import-questions.mjs --source CSA_EXAMTOPICS_READY.json",
    "import:questions:dump": "node scripts/import-questions.mjs --source CSA_EXAMTOPICS_FROM_DUMP.json",
    "audit:questions": "node scripts/audit-questions.mjs",
    "build:dump": "python scripts/build_dataset_from_dump.py --dump-dir \"data/raw-examtopics/01 - ExamTopics/01 - Respostas\" --existing-json \"CSA_EXAMTOPICS.json\" --output \"CSA_EXAMTOPICS_FROM_DUMP.json\" --cache-dir \"data/ocr-cache\" --scale 1.4"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.60.0"
  }
}
